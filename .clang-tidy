Checks:
  - '-*'
  - 'clang-analyzer-*'
  - 'bugprone-*'
  - 'performance-*'
  - 'portability-*'
  - 'misc-*'
  - 'cppcoreguidelines-*'
  - 'modernize-*'
  - 'readability-*'
  - 'hicpp-*'
  - 'concurrency-*'

  - '-hicpp-braces-around-statements'
  - '-llvm-header-guard'
  - '-modernize-use-trailing-return-type'
  - '-modernize-use-default-member-init'
  - '-misc-header-include-cycle'
  - '-readability-redundant-preprocessor'
  - '-modernize-macro-to-enum'
  - '-readability-avoid-pragma-once'
  - '-portability-avoid-pragma-once'
  - '-cppcoreguidelines-macro-to-enum'
  - '-misc-non-private-member-variables-in-classes'
# temporary, will revert in the future
  - '-misc-unused-parameters'
  - '-hicpp-uppercase-literal-suffix'
  - '-readability-uppercase-literal-suffix'

# i will probably regrert this in the future
WarningsAsErrors: '*'

HeaderFilterRegex: '.*'
FormatStyle: none

CheckOptions:
  # --- readability / structure ---
  - key: readability-braces-around-statements.ShortStatementLines
    value: '2'

  - key: readability-function-size.LineThreshold
    value: '70'

  - key: readability-function-cognitive-complexity.Threshold
    value: '18'

  - key: readability-misleading-indentation.StrictMode
    value: 'true'

  # identifier length (FIXED PROPERLY)
  - key: readability-identifier-length.MinimumVariableNameLength
    value: '2'

  - key: readability-identifier-length.MinimumParameterNameLength
    value: '2'

  # optional: allow common short names
  - key: readability-identifier-length.IgnoredVariableNames
    value: 'i;j;k;x;y;id'

  - key: readability-identifier-length.IgnoredParameterNames
    value: 'i;j;k;x;y;id'

  # --- modernize behavior ---
  - key: modernize-loop-convert.MinConfidence
    value: 'reasonable'

  - key: modernize-use-nullptr.NullMacros
    value: 'NULL'

  # --- safety tightening ---
  - key: cppcoreguidelines-pro-bounds-array-to-pointer-decay.AllowDecayInTemplates
    value: 'false'

  - key: cppcoreguidelines-init-variables
    value: '1'
