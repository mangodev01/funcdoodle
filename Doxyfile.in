PROJECT_NAME         = "FuncDoodle"
OUTPUT_DIRECTORY     = @CMAKE_CURRENT_BINARY_DIR@/doxy
INPUT                = @CMAKE_CURRENT_SOURCE_DIR@/src
RECURSIVE            = YES
FILE_PATTERNS        = *.h *.cc
GENERATE_HTML        = YES
GENERATE_LATEX       = NO
GENERATE_XML         = NO
EXTRACT_ALL          = YES
EXTRACT_PRIVATE      = YES
EXTRACT_STATIC       = YES
WARN_IF_UNDOCUMENTED = YES
WARNINGS_AS_ERROR    = NO
